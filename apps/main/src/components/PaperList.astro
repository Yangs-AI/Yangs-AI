---
import { getCollection } from "astro:content";
import { authorLinks } from "../data/papers";
import type { PaperEntry } from "../data/papers";

interface Props {
  papers: PaperEntry[];
  emptyMessage?: string;
  disableAuthorLinkForName?: string;
}

const { papers, emptyMessage = "No papers yet.", disableAuthorLinkForName } = Astro.props;

const sortedPapers = [...papers].sort(
  (a, b) => new Date(b.publishedOn).getTime() - new Date(a.publishedOn).getTime(),
);

const normalizeName = (name: string) => name.replace(/\*/g, "").trim().toLowerCase().replace(/\s+/g, " ");
const disabledAuthorName = disableAuthorLinkForName ? normalizeName(disableAuthorLinkForName) : null;

const teamMembers = await getCollection("team-members");
const memberLinkByName = new Map(
  teamMembers.map((entry) => [normalizeName(entry.data.name), `/team/members/${entry.id.replace(/\.md$/, "")}`]),
);

const globalAuthorLinkByName = new Map(
  Object.entries(authorLinks).map(([name, url]) => [normalizeName(name), url]),
);

const resolveAuthorLink = (author: { name: string; url?: string }) => {
  if (disabledAuthorName && normalizeName(author.name) === disabledAuthorName) {
    return null;
  }

  if (author.url) {
    return { href: author.url, external: /^https?:\/\//i.test(author.url) };
  }

  const globalAuthorHref = globalAuthorLinkByName.get(normalizeName(author.name));
  if (globalAuthorHref) {
    return { href: globalAuthorHref, external: /^https?:\/\//i.test(globalAuthorHref) };
  }

  const memberHref = memberLinkByName.get(normalizeName(author.name));
  if (!memberHref) {
    return null;
  }

  return { href: memberHref, external: false };
};

const formatDate = (value: string) =>
  new Date(`${value}T00:00:00`).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
  });
---

<section class="mt-8 space-y-4">
  <p class="text-xs text-zinc-400">Author roles are highlighted for quick scanning.</p>

  {sortedPapers.length === 0 ? (
    <div class="rounded-xl border border-white/15 bg-white/5 p-6 text-zinc-300">{emptyMessage}</div>
  ) : (
    sortedPapers.map((paper) => (
      <article class="rounded-xl border border-white/15 bg-white/5 p-5">
        <h2 class="text-xl font-semibold leading-snug text-zinc-100">{paper.title}</h2>
        <p class="mt-2 text-sm text-zinc-300">
          <span class="font-medium text-zinc-200">{paper.venue}</span>
          <span class="mx-2 text-zinc-500">|</span>
          <time datetime={paper.publishedOn}>{formatDate(paper.publishedOn)}</time>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2 text-sm leading-relaxed text-zinc-300">
          {paper.authors.map((author, authorIndex) => {
            const authorLink = resolveAuthorLink(author);
            const isCurrentMember = disabledAuthorName && normalizeName(author.name) === disabledAuthorName;
            const hasRole = author.isFirstAuthor || author.isCorrespondingAuthor;
            const shouldUseChip = Boolean(hasRole || isCurrentMember);
            const chipClass = [
              "author-chip",
              isCurrentMember ? "author-chip--self" : "",
              authorLink ? "author-chip--link" : "",
            ]
              .filter(Boolean)
              .join(" ");

            return (
            <span class="inline-flex items-center gap-1.5">
              {shouldUseChip ? (
                authorLink ? (
                  <a
                    href={authorLink.href}
                    target={authorLink.external ? "_blank" : undefined}
                    rel={authorLink.external ? "noreferrer" : undefined}
                    class={chipClass}
                  >
                    <span class={isCurrentMember ? "author-chip-name author-chip-name--self" : "author-chip-name"}>{author.name}</span>
                    {author.isFirstAuthor ? <span class="author-chip-label author-chip-label--first">First</span> : null}
                    {author.isCorrespondingAuthor ? <span class="author-chip-label author-chip-label--corr">Corr.</span> : null}
                    {isCurrentMember ? <span class="author-chip-label author-chip-label--me">Me</span> : null}
                  </a>
                ) : (
                  <span class={chipClass}>
                    <span class={isCurrentMember ? "author-chip-name author-chip-name--self" : "author-chip-name"}>{author.name}</span>
                    {author.isFirstAuthor ? <span class="author-chip-label author-chip-label--first">First</span> : null}
                    {author.isCorrespondingAuthor ? <span class="author-chip-label author-chip-label--corr">Corr.</span> : null}
                    {isCurrentMember ? <span class="author-chip-label author-chip-label--me">Me</span> : null}
                  </span>
                )
              ) : authorLink ? (
                <a
                  href={authorLink.href}
                  target={authorLink.external ? "_blank" : undefined}
                  rel={authorLink.external ? "noreferrer" : undefined}
                  class="author-link text-zinc-100 underline decoration-zinc-500/75 underline-offset-2 transition-colors hover:text-white"
                >
                  {author.name}
                </a>
              ) : (
                <span>{author.name}</span>
              )}
              {authorIndex < paper.authors.length - 1 ? (
                <span class="px-0.5 text-zinc-500/80" aria-hidden="true">•</span>
              ) : null}
            </span>
            );
          })}
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          {paper.bibtex ? (
            <button
              type="button"
              data-bibtex-open={paper.id}
              class="cursor-pointer rounded-lg border border-zinc-100/24 bg-white/8 px-3 py-1.5 text-xs font-medium text-zinc-100 hover:bg-white/16"
            >
              BibTeX
            </button>
          ) : (
            <span class="rounded-lg border border-zinc-100/12 bg-white/4 px-3 py-1.5 text-xs text-zinc-400">BibTeX N/A</span>
          )}

          {paper.paperUrl ? (
            <a
              href={paper.paperUrl}
              target="_blank"
              rel="noreferrer"
              class="rounded-lg border border-zinc-100/24 bg-white/8 px-3 py-1.5 text-xs font-medium text-zinc-100 hover:bg-white/16"
            >
              Paper
            </a>
          ) : (
            <span class="rounded-lg border border-zinc-100/12 bg-white/4 px-3 py-1.5 text-xs text-zinc-400">Paper N/A</span>
          )}

          {paper.codeUrl ? (
            <a
              href={paper.codeUrl}
              target="_blank"
              rel="noreferrer"
              class="rounded-lg border border-zinc-100/24 bg-white/8 px-3 py-1.5 text-xs font-medium text-zinc-100 hover:bg-white/16"
            >
              Code
            </a>
          ) : (
            <span class="rounded-lg border border-zinc-100/12 bg-white/4 px-3 py-1.5 text-xs text-zinc-400">Code N/A</span>
          )}
        </div>

        {paper.bibtex ? (
          <dialog
            id={`bibtex-dialog-${paper.id}`}
            data-bibtex-dialog
            class="bibtex-dialog m-auto w-[min(92vw,44rem)] rounded-xl border border-zinc-100/18 bg-[rgba(16,16,20,0.97)] p-0 text-zinc-100 shadow-[0_28px_60px_rgba(0,0,0,0.5)] backdrop:bg-[rgba(8,8,12,0.62)] backdrop:transition-opacity backdrop:duration-250"
          >
            <div class="border-b border-white/10 px-4 py-3">
              <div class="flex items-start justify-between gap-3">
                <p class="pr-4 text-sm font-medium leading-relaxed">{paper.title}</p>
                <div class="flex shrink-0 items-center gap-2">
                  <button
                    type="button"
                    data-bibtex-copy={paper.id}
                    class="cursor-pointer rounded-md border border-white/18 bg-white/6 px-2 py-1 text-xs text-zinc-200 hover:bg-white/14"
                  >
                    Copy
                  </button>
                  <button
                    type="button"
                    data-bibtex-close={paper.id}
                    class="cursor-pointer rounded-md border border-white/18 bg-white/6 px-2 py-1 text-xs text-zinc-200 hover:bg-white/14"
                  >
                    Close
                  </button>
                </div>
              </div>
            </div>
            <pre class="max-h-[62vh] overflow-auto px-4 py-3 text-xs leading-relaxed text-zinc-200">{paper.bibtex}</pre>
          </dialog>
        ) : null}
      </article>
    ))
  )}
</section>

<style>
  .author-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.12rem;
    border: 1px solid rgba(148, 163, 184, 0.28);
    background: rgba(61, 81, 119, 0.22);
    color: #e5e7eb;
    border-radius: 0.62rem;
    padding: 0.18rem 0.62rem;
    text-decoration: none;
  }

  .author-chip--link {
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .author-chip--link:hover {
    background: rgba(82, 109, 160, 0.32);
    border-color: rgba(191, 219, 254, 0.38);
    color: #ffffff;
  }

  .author-chip--self {
    border-color: rgba(110, 231, 183, 0.34);
    background: rgba(110, 231, 183, 0.1);
  }

  .author-chip-name {
    line-height: 1.2;
  }

  .author-chip-name--self {
    font-weight: 600;
  }

  .author-chip-label {
    border-radius: 999px;
    padding: 0.02rem 0.24rem;
    font-size: 0.54rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .author-chip-name + .author-chip-label {
    margin-left: 0.08rem;
  }

  .author-chip-label + .author-chip-label {
    margin-left: -0.04rem;
  }

  .author-chip-label--first {
    background: rgba(217, 70, 239, 0.2);
    color: #fae8ff;
  }

  .author-chip-label--corr {
    background: rgba(139, 92, 246, 0.22);
    color: #ede9fe;
  }

  .author-chip-label--me {
    background: rgba(16, 185, 129, 0.2);
    color: #a7f3d0;
  }

  :global(html[data-theme="light"] .author-chip) {
    border-color: rgba(71, 85, 105, 0.24);
    background: rgba(224, 235, 252, 0.72);
    color: #1e293b;
  }

  :global(html[data-theme="light"] .author-chip--link:hover) {
    background: rgba(59, 130, 246, 0.12);
    border-color: rgba(37, 99, 235, 0.36);
    color: #1e3a8a;
  }

  :global(html[data-theme="light"] .author-chip--self) {
    border-color: rgba(15, 118, 110, 0.34);
    background: rgba(20, 184, 166, 0.12);
    color: #0f766e;
  }

  :global(html[data-theme="light"] .author-chip-label--first) {
    background: rgba(217, 70, 239, 0.16);
    color: #86198f;
  }

  :global(html[data-theme="light"] .author-chip-label--corr) {
    background: rgba(139, 92, 246, 0.18);
    color: #6d28d9;
  }

  :global(html[data-theme="light"] .author-chip-label--me) {
    background: rgba(20, 184, 166, 0.16);
    color: #0f766e;
  }

  :global(.bibtex-dialog) {
    opacity: 0;
    transform: translateY(12px) scale(0.98);
    transition: opacity 220ms ease, transform 260ms cubic-bezier(0.2, 0.75, 0.2, 1);
  }

  :global(.bibtex-dialog[open].is-visible) {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  :global(.bibtex-dialog::backdrop) {
    opacity: 0;
    transition: opacity 220ms ease;
  }

  :global(.bibtex-dialog[open].is-visible::backdrop) {
    opacity: 1;
  }

  :global(html[data-theme="light"] .bibtex-dialog) {
    border-color: rgba(51, 65, 85, 0.25);
    background: rgba(251, 254, 255, 0.98);
    color: #0f172a;
    box-shadow: 0 26px 56px rgba(92, 120, 156, 0.26);
  }

  :global(html[data-theme="light"] .bibtex-dialog::backdrop) {
    background: rgba(42, 57, 81, 0.26);
  }
</style>

<script>
  const openButtons = document.querySelectorAll("[data-bibtex-open]");

  openButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const paperId = button.getAttribute("data-bibtex-open");
      const dialog = document.getElementById(`bibtex-dialog-${paperId}`);
      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
        window.requestAnimationFrame(() => {
          dialog.classList.add("is-visible");
        });
      }
    });
  });

  const closeButtons = document.querySelectorAll("[data-bibtex-close]");
  closeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const paperId = button.getAttribute("data-bibtex-close");
      const dialog = document.getElementById(`bibtex-dialog-${paperId}`);
      if (dialog instanceof HTMLDialogElement) {
        dialog.classList.remove("is-visible");
        window.setTimeout(() => {
          if (dialog.open) {
            dialog.close();
          }
        }, 220);
      }
    });
  });

  const copyButtons = document.querySelectorAll("[data-bibtex-copy]");
  copyButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const paperId = button.getAttribute("data-bibtex-copy");
      const dialog = document.getElementById(`bibtex-dialog-${paperId}`);
      if (!(dialog instanceof HTMLDialogElement)) {
        return;
      }

      const content = dialog.querySelector("pre")?.textContent ?? "";
      if (!content.trim()) {
        return;
      }

      try {
        await navigator.clipboard.writeText(content);
        if (button instanceof HTMLButtonElement) {
          const original = button.textContent;
          button.textContent = "Copied";
          window.setTimeout(() => {
            button.textContent = original;
          }, 1200);
        }
      } catch {
        if (button instanceof HTMLButtonElement) {
          const original = button.textContent;
          button.textContent = "Failed";
          window.setTimeout(() => {
            button.textContent = original;
          }, 1200);
        }
      }
    });
  });

  const dialogs = document.querySelectorAll("dialog[id^='bibtex-dialog-']");
  dialogs.forEach((dialog) => {
    dialog.addEventListener("click", (event) => {
      const target = event.currentTarget;
      if (!(target instanceof HTMLDialogElement)) return;

      if (event.target === target) {
        target.classList.remove("is-visible");
        window.setTimeout(() => {
          if (target.open) {
            target.close();
          }
        }, 220);
      }
    });

    dialog.addEventListener("cancel", (event) => {
      event.preventDefault();
      if (!(dialog instanceof HTMLDialogElement)) {
        return;
      }

      dialog.classList.remove("is-visible");
      window.setTimeout(() => {
        if (dialog.open) {
          dialog.close();
        }
      }, 220);
    });
  });
</script>
