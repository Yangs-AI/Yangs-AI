---
import { getCollection } from "astro:content";
import SubpageLayout from "../../../layouts/SubpageLayout.astro";
import BackButton from "../../../components/BackButton.astro";
import { buildFallbackAvatar } from "../../../utils/memberAvatar";
import type { AvatarGender } from "../../../utils/memberAvatar";

type StudentLevel = "undergraduate" | "master" | "phd";
type StudentStatus = "current" | "graduated";
type InternStatus = "current" | "completed";
type EmployeeStatus = "current" | "past";
type InternshipDegreeStatus =
  | "undergraduate_studying"
  | "undergraduate_graduated"
  | "master_studying"
  | "master_graduated"
  | "phd_studying"
  | "phd_graduated"
  | "other";

const levelMeta: Array<{ key: StudentLevel; label: string }> = [
  { key: "phd", label: "PhD" },
  { key: "master", label: "Master" },
  { key: "undergraduate", label: "Undergraduate" },
];

const studentStatusText = (status: StudentStatus) => (status === "graduated" ? "Graduated Student" : "Current Student");
const internStatusText = (status: InternStatus) => (status === "completed" ? "Past Intern" : "Current Intern");
const employeeStatusText = (status: EmployeeStatus) => (status === "past" ? "Past Employee" : "Current Employee");
const internshipDegreeStatusText = (status: InternshipDegreeStatus) =>
  status === "undergraduate_studying"
    ? "Pursuing Bachelor's Degree"
    : status === "undergraduate_graduated"
    ? "Awarded Bachelor's Degree"
    : status === "master_studying"
    ? "Pursuing Master's Degree"
    : status === "master_graduated"
    ? "Awarded Master's Degree"
    : status === "phd_studying"
    ? "Pursuing PhD Degree"
    : status === "phd_graduated"
    ? "Awarded PhD Degree"
    : "Other";

const getAvatarSources = (member: Member) => {
  const fallback = buildFallbackAvatar(member.name, member.memberType, member.avatarGender ?? "neutral");
  return {
    src: member.avatar || fallback,
    fallback,
  };
};

const memberEntries = await getCollection("team-members");

type Member = {
  slug: string;
  order: number;
} & (typeof memberEntries)[number]["data"];

type EmployeeMember = Extract<Member, { memberType: "employee" }>;
type StudentMember = Extract<Member, { memberType: "student" }>;
type InternMember = Extract<Member, { memberType: "intern" }>;

const isEmployeeMember = (member: Member): member is EmployeeMember => member.memberType === "employee";
const isStudentMember = (member: Member): member is StudentMember => member.memberType === "student";
const isInternMember = (member: Member): member is InternMember => member.memberType === "intern";

const members: Member[] = memberEntries
  .map((entry) => ({
    slug: entry.id.replace(/\.md$/, ""),
    ...entry.data,
    order: entry.data.order ?? 999,
  }))
  .sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));

const employees = members.filter(isEmployeeMember);
const interns = members.filter(isInternMember);

const buildStudentGroups = (graduated: boolean) =>
  levelMeta
    .map((level) => ({
      ...level,
      members: members.filter(isStudentMember).filter(
        (member) =>
          (graduated ? member.studentStatus === "graduated" : member.studentStatus === "current") &&
          member.studentLevel === level.key,
      ),
    }))
    .filter((group) => group.members.length > 0);

const currentStudentGroups = buildStudentGroups(false);
const alumniStudentGroups = buildStudentGroups(true);
const currentEmployees = employees
  .filter((member) => member.employeeStatus === "current")
  .sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));
const alumniEmployees = employees
  .filter((member) => member.employeeStatus === "past")
  .sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));
const currentInterns = interns
  .filter((member) => member.internStatus === "current")
  .sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));
const alumniInterns = interns
  .filter((member) => member.internStatus === "completed")
  .sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));

const formatPeriod = (period: { start: string; end?: string }) => (period.end ? `${period.start} - ${period.end}` : `${period.start} - Present`);

const formatDestination = (destination: {
  status: string;
  organization?: string;
  role?: string;
  location?: string;
}) => [destination.status, destination.organization, destination.role, destination.location].filter(Boolean).join(" · ");

const quickLinks = [
  { href: "#students-current", label: "Current Students", enabled: currentStudentGroups.length > 0 },
  { href: "#students-graduated", label: "Graduated Students", enabled: alumniStudentGroups.length > 0 },
  { href: "#interns-current", label: "Current Interns", enabled: currentInterns.length > 0 },
  { href: "#interns-past", label: "Past Interns", enabled: alumniInterns.length > 0 },
  { href: "#employees-current", label: "Current Employees", enabled: currentEmployees.length > 0 },
  { href: "#employees-past", label: "Past Employees", enabled: alumniEmployees.length > 0 },
].filter((item) => item.enabled);
---

<SubpageLayout title="Team | Members | Yangs AI" description="YangsAI team members and profiles.">
  <BackButton href="/team" label="Back to Team" />
  <p class="font-tech mt-5 text-xs uppercase tracking-[0.12em] text-zinc-300">Team</p>
  <h1 id="members-top" class="mt-2 text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">Members</h1>

  {quickLinks.length > 0 ? (
    <nav id="members-nav" class="mt-5 rounded-xl border border-white/12 bg-white/4 p-3 md:p-4" aria-label="Member section quick links">
      <p class="font-tech text-[0.65rem] uppercase tracking-[0.12em] text-zinc-300">Quick Navigation</p>
      <div class="mt-2 flex flex-wrap gap-2">
        {quickLinks.map((item) => (
          <a href={item.href} class="rounded-md border border-white/18 bg-white/7 px-2.5 py-1 text-xs text-zinc-200 hover:bg-white/14">
            {item.label}
          </a>
        ))}
      </div>
    </nav>
  ) : null}

  {currentEmployees.length === 0 && alumniEmployees.length === 0 && currentStudentGroups.length === 0 && alumniStudentGroups.length === 0 && currentInterns.length === 0 && alumniInterns.length === 0 ? (
    <section class="mt-8 rounded-xl border border-white/12 bg-white/5 p-6 text-zinc-300">
      No team members are published yet. Add markdown files under `src/content/team-members/`.
    </section>
  ) : null}

  {currentStudentGroups.length > 0 || alumniStudentGroups.length > 0 ? (
    <section class="mt-8">
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Students</p>

      {currentStudentGroups.length > 0 ? (
        <div id="students-current" class="mt-5 rounded-2xl border border-white/12 bg-white/4 p-4 md:p-5" data-student-section="current">
          <div class="flex items-center justify-between gap-3">
            <p class="font-tech text-[0.7rem] uppercase tracking-[0.12em] text-zinc-300">Current Students</p>
            <a href="#members-nav" class="text-[0.68rem] text-zinc-400 underline decoration-zinc-500/70 underline-offset-4 hover:text-zinc-200">
              Back to Navigation
            </a>
          </div>
          {currentStudentGroups.map((group) => (
            <div class="mt-4 ml-1 rounded-xl border border-white/10 bg-white/4 p-3 md:ml-2" data-student-level-group>
              <p class="font-tech text-[0.62rem] uppercase tracking-[0.12em] text-zinc-400">Level · {group.label}</p>
              <div class="mt-2 grid gap-4 md:grid-cols-2">
                {group.members.map((member) => (
                  <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
                    {(() => {
                      const avatar = getAvatarSources(member);
                      return (
                    <div class="flex items-center gap-3">
                      <img
                        src={avatar.src}
                        alt={`${member.name} portrait`}
                        class="h-14 w-14 rounded-full border border-white/16 object-cover"
                        loading="lazy"
                        decoding="async"
                        data-fallback-src={avatar.fallback}
                      />
                      <div>
                        <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                        <p class="mt-1 text-sm text-zinc-300">{member.role}</p>
                      </div>
                    </div>
                      );
                    })()}
                    <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
                    <p class="mt-2 text-xs text-zinc-400">In Lab: {formatPeriod(member.periodAtLab)}</p>
                    <div class="mt-2 text-xs text-zinc-400">{studentStatusText(member.studentStatus)}</div>
                    {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : null}

      {alumniStudentGroups.length > 0 ? (
        <div id="students-graduated" class="mt-7 rounded-2xl border border-white/12 bg-white/4 p-4 md:p-5" data-student-section="graduated">
          <div class="flex items-center justify-between gap-3">
            <p class="font-tech text-[0.7rem] uppercase tracking-[0.12em] text-zinc-300">Graduated Students</p>
            <a href="#members-nav" class="text-[0.68rem] text-zinc-400 underline decoration-zinc-500/70 underline-offset-4 hover:text-zinc-200">
              Back to Navigation
            </a>
          </div>
          {alumniStudentGroups.map((group) => (
            <div class="mt-4 ml-1 rounded-xl border border-white/10 bg-white/4 p-3 md:ml-2" data-student-level-group>
              <p class="font-tech text-[0.62rem] uppercase tracking-[0.12em] text-zinc-400">Level · {group.label}</p>
              <div class="mt-2 grid gap-4 md:grid-cols-2">
                {group.members.map((member) => (
                  <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
                    {(() => {
                      const avatar = getAvatarSources(member);
                      return (
                    <div class="flex items-center gap-3">
                      <img
                        src={avatar.src}
                        alt={`${member.name} portrait`}
                        class="h-14 w-14 rounded-full border border-white/16 object-cover"
                        loading="lazy"
                        decoding="async"
                        data-fallback-src={avatar.fallback}
                      />
                      <div>
                        <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                        <p class="mt-1 text-sm text-zinc-300">{member.role}</p>
                      </div>
                    </div>
                      );
                    })()}
                    <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
                    <p class="mt-2 text-xs text-zinc-400">In Lab: {formatPeriod(member.periodAtLab)}</p>
                    <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                      <span class="text-zinc-400">{studentStatusText(member.studentStatus)}</span>
                      {member.graduationYear ? <span class="text-zinc-400">Class of {member.graduationYear}</span> : null}
                    </div>
                    {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : null}
    </section>
  ) : null}

  {currentInterns.length > 0 || alumniInterns.length > 0 ? (
    <section class="mt-8">
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Interns</p>
      {currentInterns.length > 0 ? (
        <div id="interns-current" class="mt-5 rounded-2xl border border-white/12 bg-white/4 p-4 md:p-5" data-intern-section="current">
          <div class="flex items-center justify-between gap-3">
            <p class="font-tech text-[0.7rem] uppercase tracking-[0.12em] text-zinc-300">Current Interns</p>
            <a href="#members-nav" class="text-[0.68rem] text-zinc-400 underline decoration-zinc-500/70 underline-offset-4 hover:text-zinc-200">
              Back to Navigation
            </a>
          </div>
          <div class="mt-2 grid gap-4 md:grid-cols-2">
            {currentInterns.map((member) => (
              <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
                {(() => {
                  const avatar = getAvatarSources(member);
                  return (
                <div class="flex items-center gap-3">
                  <img
                    src={avatar.src}
                    alt={`${member.name} portrait`}
                    class="h-14 w-14 rounded-full border border-white/16 object-cover"
                    loading="lazy"
                    decoding="async"
                    data-fallback-src={avatar.fallback}
                  />
                  <div>
                    <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                    <p class="mt-1 text-sm text-zinc-300">{member.role}</p>
                  </div>
                </div>
                  );
                })()}
                <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
                <p class="mt-2 text-xs text-zinc-400">Affiliation: {member.sourceInstitution}</p>
                <p class="mt-1 text-xs text-zinc-400">Degree Status: {internshipDegreeStatusText(member.internshipDegreeStatus)}</p>
                <p class="mt-1 text-xs text-zinc-400">In Lab: {formatPeriod(member.periodAtLab)}</p>
                <div class="mt-2 text-xs text-zinc-400">{internStatusText(member.internStatus)}</div>
                {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
              </a>
            ))}
          </div>
        </div>
      ) : null}
      {alumniInterns.length > 0 ? (
        <div id="interns-past" class="mt-7 rounded-2xl border border-white/12 bg-white/4 p-4 md:p-5" data-intern-section="completed">
          <div class="flex items-center justify-between gap-3">
            <p class="font-tech text-[0.7rem] uppercase tracking-[0.12em] text-zinc-300">Past Interns</p>
            <a href="#members-nav" class="text-[0.68rem] text-zinc-400 underline decoration-zinc-500/70 underline-offset-4 hover:text-zinc-200">
              Back to Navigation
            </a>
          </div>
          <div class="mt-2 grid gap-4 md:grid-cols-2">
            {alumniInterns.map((member) => (
              <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
                {(() => {
                  const avatar = getAvatarSources(member);
                  return (
                <div class="flex items-center gap-3">
                  <img
                    src={avatar.src}
                    alt={`${member.name} portrait`}
                    class="h-14 w-14 rounded-full border border-white/16 object-cover"
                    loading="lazy"
                    decoding="async"
                    data-fallback-src={avatar.fallback}
                  />
                  <div>
                    <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                    <p class="mt-1 text-sm text-zinc-300">{member.role}</p>
                  </div>
                </div>
                  );
                })()}
                <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
                <p class="mt-2 text-xs text-zinc-400">Affiliation: {member.sourceInstitution}</p>
                <p class="mt-1 text-xs text-zinc-400">Degree Status: {internshipDegreeStatusText(member.internshipDegreeStatus)}</p>
                <p class="mt-1 text-xs text-zinc-400">In Lab: {formatPeriod(member.periodAtLab)}</p>
                <div class="mt-2 text-xs text-zinc-400">{internStatusText(member.internStatus)}</div>
                {member.currentDestination ? (
                  <p class="mt-1 text-xs text-zinc-400">
                    Now: {formatDestination(member.currentDestination)} · Updated: {member.currentDestination.updatedOn}
                  </p>
                ) : null}
                {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
              </a>
            ))}
          </div>
        </div>
      ) : null}
    </section>
  ) : null}

  {currentEmployees.length > 0 || alumniEmployees.length > 0 ? (
    <section class="mt-8">
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Employees</p>
      {currentEmployees.length > 0 ? (
        <div id="employees-current" class="mt-5 rounded-2xl border border-white/12 bg-white/4 p-4 md:p-5">
          <div class="flex items-center justify-between gap-3">
            <p class="font-tech text-[0.7rem] uppercase tracking-[0.12em] text-zinc-300">Current Employees</p>
            <a href="#members-nav" class="text-[0.68rem] text-zinc-400 underline decoration-zinc-500/70 underline-offset-4 hover:text-zinc-200">
              Back to Navigation
            </a>
          </div>
          <div class="mt-2 grid gap-4 md:grid-cols-2">
            {currentEmployees.map((member) => (
              <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
                {(() => {
                  const avatar = getAvatarSources(member);
                  return (
                <div class="flex items-center gap-3">
                  <img
                    src={avatar.src}
                    alt={`${member.name} portrait`}
                    class="h-14 w-14 rounded-full border border-white/16 object-cover"
                    loading="lazy"
                    decoding="async"
                    data-fallback-src={avatar.fallback}
                  />
                  <div>
                    <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                    <p class="mt-1 text-sm text-zinc-300">{member.role}</p>
                  </div>
                </div>
                  );
                })()}
                <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
                <p class="mt-2 text-xs text-zinc-400">In Lab: {formatPeriod(member.periodAtLab)}</p>
                <div class="mt-2 text-xs text-zinc-400">{employeeStatusText(member.employeeStatus)}</div>
                {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
              </a>
            ))}
          </div>
        </div>
      ) : null}
      {alumniEmployees.length > 0 ? (
        <div id="employees-past" class="mt-7 rounded-2xl border border-white/12 bg-white/4 p-4 md:p-5">
          <div class="flex items-center justify-between gap-3">
            <p class="font-tech text-[0.7rem] uppercase tracking-[0.12em] text-zinc-300">Past Employees</p>
            <a href="#members-nav" class="text-[0.68rem] text-zinc-400 underline decoration-zinc-500/70 underline-offset-4 hover:text-zinc-200">
              Back to Navigation
            </a>
          </div>
          <div class="mt-2 grid gap-4 md:grid-cols-2">
            {alumniEmployees.map((member) => (
              <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
                {(() => {
                  const avatar = getAvatarSources(member);
                  return (
                <div class="flex items-center gap-3">
                  <img
                    src={avatar.src}
                    alt={`${member.name} portrait`}
                    class="h-14 w-14 rounded-full border border-white/16 object-cover"
                    loading="lazy"
                    decoding="async"
                    data-fallback-src={avatar.fallback}
                  />
                  <div>
                    <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                    <p class="mt-1 text-sm text-zinc-300">{member.role}</p>
                  </div>
                </div>
                  );
                })()}
                <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
                <p class="mt-2 text-xs text-zinc-400">In Lab: {formatPeriod(member.periodAtLab)}</p>
                <div class="mt-2 text-xs text-zinc-400">{employeeStatusText(member.employeeStatus)}</div>
                {member.currentDestination ? (
                  <p class="mt-1 text-xs text-zinc-400">
                    Now: {formatDestination(member.currentDestination)} · Updated: {member.currentDestination.updatedOn}
                  </p>
                ) : null}
                {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
              </a>
            ))}
          </div>
        </div>
      ) : null}
    </section>
  ) : null}

  <script>
    document.querySelectorAll("img[data-fallback-src]").forEach((img) => {
      img.addEventListener("error", () => {
        const fallback = img.getAttribute("data-fallback-src");
        if (!fallback || img.getAttribute("src") === fallback) return;
        img.setAttribute("src", fallback);
      });
    });
  </script>
</SubpageLayout>
