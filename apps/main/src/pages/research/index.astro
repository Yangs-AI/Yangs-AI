---
import SubpageLayout from "../../layouts/SubpageLayout.astro";
import BackButton from "../../components/BackButton.astro";
---

<SubpageLayout
  title="Research | About | Yangs AI"
  description="About Yangs AI research, including papers, projects, and long-term directions."
>
  <BackButton href="/" label="Back to Home" />
  <p class="font-tech mt-5 text-xs uppercase tracking-[0.14em] text-zinc-300">Yangs AI</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">About Research</h1>
  <p class="mt-4 max-w-3xl text-base leading-relaxed text-zinc-300">
    This section collects the core research threads of Yangs AI. Use the pages below to browse publications,
    ongoing projects, and forward-looking directions.
  </p>

  <div class="mt-10 grid gap-4">
    <a
      class="rounded-2xl border border-white/15 bg-white/5 p-6 transition hover:border-white/30 hover:bg-white/10"
      href="/research/papers"
    >
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Research</p>
      <p class="mt-2 text-2xl font-medium text-zinc-100">Papers</p>
      <p class="mt-2 max-w-3xl text-sm text-zinc-300">Published and selected papers across core and emerging topics.</p>
      <p class="font-tech mt-4 text-xs uppercase tracking-[0.12em] text-zinc-200">Visit Track</p>
    </a>

    <a
      class="rounded-2xl border border-white/15 bg-white/5 p-6 transition hover:border-white/30 hover:bg-white/10"
      href="/research/projects"
    >
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Research</p>
      <p class="mt-2 text-2xl font-medium text-zinc-100">Projects</p>
      <p class="mt-2 max-w-3xl text-sm text-zinc-300">Current and archived project tracks with evolving implementation status.</p>
      <p class="font-tech mt-4 text-xs uppercase tracking-[0.12em] text-zinc-200">Visit Track</p>
    </a>

    <a
      class="rounded-2xl border border-white/15 bg-white/5 p-6 transition hover:border-white/30 hover:bg-white/10"
      href="/research/directions"
    >
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Research</p>
      <p class="mt-2 text-2xl font-medium text-zinc-100">Directions</p>
      <p class="mt-2 max-w-3xl text-sm text-zinc-300">Long-term ideas and exploratory threads shaping future Yangs AI work.</p>
      <p class="font-tech mt-4 text-xs uppercase tracking-[0.12em] text-zinc-200">Visit Track</p>
    </a>
  </div>
</SubpageLayout>
